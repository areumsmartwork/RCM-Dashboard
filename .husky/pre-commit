#!/bin/sh

FRONTEND_DIR="$(git rev-parse --show-toplevel)/frontend"
BACKEND_DIR="$(git rev-parse --show-toplevel)/backend"

# ── Frontend ──────────────────────────────────────────────────
if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
  echo "⚠️  Frontend node_modules 없음 — lint 건너뜀 (npm install 필요)"
else
  echo "🔍 Frontend lint..."
  (cd "$FRONTEND_DIR" && npm run lint)
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Frontend lint 실패 — 오류를 수정하고 다시 커밋하세요."
    exit 1
  fi
fi

# ── Backend ───────────────────────────────────────────────────
if [ ! -d "$BACKEND_DIR/node_modules" ]; then
  echo "⚠️  Backend node_modules 없음 — lint 건너뜀 (npm install 필요)"
else
  echo "🔍 Backend lint..."
  (cd "$BACKEND_DIR" && npm run lint:check)
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Backend lint 실패 — 오류를 수정하고 다시 커밋하세요."
    exit 1
  fi
fi

echo "✅ Lint 통과"
